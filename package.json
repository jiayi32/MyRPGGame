{
  "name": "typayments",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "rn-nodeify --install crypto,fs,https --hack && patch-package && node scripts/fix-rn78-propTypes.js",
    "android:clean": "cd android && gradlew clean && cd ..",
    "android:clean:win": "cd android && gradlew.bat clean && cd .."
  },
  "dependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@expo/vector-icons": "^14.0.4",
    "@expo/webpack-config": "^19.0.1",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.5",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.4",
    "@react-native-masked-view/masked-view": "^0.3.1",
    "@react-native-ml-kit/text-recognition": "^1.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.5.7",
    "@react-navigation/native": "^6.1.3",
    "@react-navigation/native-stack": "^6.9.9",
    "@shopify/react-native-skia": "2.0.0-next.4",
    "buffer": "^6.0.3",
    "deprecated-react-native-prop-types": "^5.0.0",
    "dotenv": "^17.2.3",
    "expo": "~53.0.27",
    "expo-auth-session": "~6.2.1",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-camera": "~16.1.11",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-local-authentication": "~16.0.5",
    "expo-location": "~18.1.6",
    "expo-mesh-gradient": "~0.3.4",
    "expo-notifications": "~0.31.5",
    "expo-print": "~14.1.4",
    "expo-secure-store": "~14.2.4",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "firebase": "^11.1.0",
    "https-browserify": "^1.0.0",
    "lottie-react-native": "7.2.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-base64": "^0.2.1",
    "react-native-crypto": "^2.2.0",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-gifted-charts": "^1.4.74",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-level-fs": "^3.0.1",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-randombytes": "^3.6.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-uuid": "^2.0.1",
    "react-native-web": "^0.20.0",
    "rn-nodeify": "^10.3.0",
    "stream": "^0.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "latest",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "~19.0.10",
    "@types/react-native-fs": "^2.13.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.2.4",
    "typescript": "~5.8.3"
  },
  "private": true,
  "react-native": {
    "crypto": "react-native-crypto",
    "https": "https-browserify",
    "fs": "react-native-level-fs"
  },
  "browser": {
    "crypto": "react-native-crypto",
    "https": "https-browserify",
    "fs": "react-native-level-fs"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "jest": {
    "preset": "react-native",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/**/*.test.{js,jsx}",
      "!src/**/index.{js,jsx}",
      "!src/config/**",
      "!src/navigation/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testMatch": [
      "**/__tests__/**/*.{js,jsx}",
      "**/*.{spec,test}.{js,jsx}"
    ],
    "testPathIgnorePatterns": [
      "__tests__/fixtures"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|firebase|@firebase)"
    ]
  }
}
